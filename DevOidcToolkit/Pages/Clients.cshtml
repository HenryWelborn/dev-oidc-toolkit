@page "/clients"
@using System.Text.Json
@using DevOidcToolkit.Infrastructure.Configuration
@inject DevOidcToolkitConfiguration Config
@model DevOidcToolkit.Pages.ClientsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Clients";
}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">@Config.ApplicationTitle</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/users">Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" aria-current="page" href="/clients">Clients</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container my-5">

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Clients</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createClientModal">
        <i class="bi bi-plus-circle"></i> Create New Client
    </button>
</div>

@{
    var clients = Model.Clients ?? [];
}

@if (clients?.Any() == true)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th scope="col">Client ID</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in clients)
                {
                    var rowId = $"client-{client.ClientId?.Replace(" ", "-")}";
                    <tr>
                        <td>@client.ClientId</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#@rowId" aria-expanded="false" aria-controls="@rowId">
                                <i class="bi bi-eye"></i> View Details
                            </button>
                        </td>
                    </tr>
                    <tr class="collapse" id="@rowId">
                        <td colspan="2">
                            <div class="card card-body bg-light">
                                @{
                                    var options = new JsonSerializerOptions { WriteIndented = true };
                                    var json = JsonSerializer.Serialize(client, options);
                                }
                                <pre class="mb-0"><code>@Html.Raw(json)</code></pre>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> No clients found
    </div>
}

<!-- Create Client Modal -->
<div class="modal fade" id="createClientModal" tabindex="-1" aria-labelledby="createClientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createClientModalLabel">Create New Client</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="clientId" class="form-label">Client ID</label>
                        <input type="text" class="form-control" id="clientId" name="Input.ClientId" required />
                        <span asp-validation-for="Input.ClientId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label for="clientSecret" class="form-label">Client Secret</label>
                        <input type="text" class="form-control" id="clientSecret" name="Input.ClientSecret" required />
                        <span asp-validation-for="Input.ClientSecret" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label for="redirectUris" class="form-label">Redirect URIs (comma-separated)</label>
                        <input type="text" class="form-control" id="redirectUris" name="Input.RedirectUris" placeholder="e.g., http://localhost:3000/callback, https://example.com/callback" />
                        <span asp-validation-for="Input.RedirectUris" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label for="postLogoutRedirectUris" class="form-label">Post-Logout Redirect URIs (comma-separated)</label>
                        <input type="text" class="form-control" id="postLogoutRedirectUris" name="Input.PostLogoutRedirectUris" placeholder="e.g., http://localhost:3000, https://example.com" />
                        <span asp-validation-for="Input.PostLogoutRedirectUris" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Client</button>
                </div>
            </form>
        </div>
    </div>
</div>

</div>