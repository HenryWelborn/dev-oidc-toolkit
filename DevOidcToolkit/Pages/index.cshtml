@page
@using DevOidcToolkit.Infrastructure.Configuration
@inject DevOidcToolkitConfiguration Config
@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">@Config.ApplicationTitle</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link active" aria-current="page" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/users">Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/clients">Clients</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container my-5">
    <div class="p-5 text-center bg-body-tertiary rounded-3">
        <h1 class="text-body-emphasis">Welcome to @Config.ApplicationTitle</h1>
        <p class="col-lg-6 mx-auto mb-4">A simple OpenID Connect identity provider for development and testing.</p>
    </div>
    
    <div class="row g-4 py-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-person-square text-primary mb-3" style="font-size: 3rem;"></i>
                    <h5 class="card-title">User Profile</h5>
                    <p class="card-text">View and manage your user profile</p>
                    <a href="/user" class="btn btn-primary">Go to Profile</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill text-primary mb-3" style="font-size: 3rem;"></i>
                    <h5 class="card-title">View Users</h5>
                    <p class="card-text">Browse and manage all users</p>
                    <a href="/users" class="btn btn-primary">View Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-server text-primary mb-3" style="font-size: 3rem;"></i>
                    <h5 class="card-title">View Clients</h5>
                    <p class="card-text">Manage OAuth/OIDC clients</p>
                    <a href="/clients" class="btn btn-primary">View Clients</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row py-3">
        <div class="col-12">
            <nav class="list-group">
                <a href="/.well-known/openid-configuration" class="list-group-item list-group-item-action d-flex gap-3 py-3">
                    <i class="bi bi-file-earmark-code-fill me-2 fs-3 text-primary"></i>
                    <div class="d-flex gap-2 w-100 justify-content-between">
                        <div>
                            <h6 class="mb-0">OpenID Connect configuration</h6>
                        </div>
                    </div>
                </a>
                <a href="@(Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development" ? "http://localhost:3001" : "/documentation")" class="list-group-item list-group-item-action d-flex gap-3 py-3">
                    <i class="bi bi-book-half me-2 fs-3 text-primary"></i>
                    <div class="d-flex gap-2 w-100 justify-content-between">
                        <div>
                            <h6 class="mb-0">Documentation</h6>
                        </div>
                    </div>
                </a>
            </nav>
        </div>
    </div>
</div>
