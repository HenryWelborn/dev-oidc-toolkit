@page "/user"
@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize]
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Profile";
}

<div class="container my-5"> 
<nav aria-label="breadcrumb">
 <ol class="breadcrumb p-3 bg-body-tertiary rounded-3"> 
 <li class="breadcrumb-item"><a href="/">Home</a></li>
 </ol> </nav>
<div class="p-5 text-center bg-body-tertiary rounded-3">
<i class="bi bi-person-square text-primary mb-4" style="font-size: 4rem;"></i>
<h1 class="text-body-emphasis">User Profile</h1> 
<p class="col-lg-6 mx-auto mb-4">
    <strong>Welcome,</strong> <span class="user-name">@User.Identity!.Name</span>
</p> 
<form action="./logout" method="post">
    @Html.AntiForgeryToken()
    <button class="btn btn-primary px-5 mb-5" type="submit">
        Log out
    </button>
</form>
 </div> </div>